#!/usr/bin/env bash
# Manual (re)start of OpenVPN. Used when the VPN drops or you want to switch
# config. Picks the first *.ovpn under /vpn/ unless VPN_CONFIG is overridden.
set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

LOG=/var/log/openvpn.log
PIDFILE=/run/openvpn.pid
AUTH_FILE="${AUTH_FILE:-/vpn/auth.txt}"

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "openvpn 已經在跑（pid $(cat "$PIDFILE")），如要重啟請先 vpn-down。"
    exit 0
fi

if [[ -n "${VPN_CONFIG:-}" ]]; then
    [[ -f "$VPN_CONFIG" ]] || { echo "找不到 $VPN_CONFIG" >&2; exit 1; }
else
    shopt -s nullglob
    ovpns=(/vpn/*.ovpn)
    shopt -u nullglob
    (( ${#ovpns[@]} > 0 )) || { echo "/vpn 中沒有 .ovpn 檔" >&2; exit 1; }
    VPN_CONFIG="${ovpns[0]}"
fi

if [[ ! -c /dev/net/tun ]]; then
    mkdir -p /dev/net
    mknod /dev/net/tun c 10 200
    chmod 600 /dev/net/tun
fi

ARGS=(--config "$VPN_CONFIG" --daemon --log "$LOG" --writepid "$PIDFILE" --script-security 2)
[[ -f "$AUTH_FILE" ]] && ARGS+=(--auth-user-pass "$AUTH_FILE")

cd "$(dirname "$VPN_CONFIG")"
openvpn "${ARGS[@]}"

echo -n "等待 tun0 上線"
for i in {1..30}; do
    if ip link show tun0 >/dev/null 2>&1; then
        echo " ✓"
        ip addr show tun0 | sed -n 's/.*inet \([0-9.\/]*\).*/  tun0 IP: \1/p'
        echo "  log: $LOG"
        echo
        echo "host 端 browser 已連 SOCKS5 proxy，可直接開 http://靶機IP/ 連靶機"
        exit 0
    fi
    sleep 1
    echo -n "."
done

echo " ✗"
echo "tun0 沒在 30 秒內上線，請檢查 $LOG" >&2
exit 1
